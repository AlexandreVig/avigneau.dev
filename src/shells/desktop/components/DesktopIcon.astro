---
interface Props {
  label: string;
  icon: string;
  /** File path (for files) or start path (for explorer shortcuts). */
  path?: string | null;
  /** App to launch. If omitted, path drives default-app resolution. */
  appId?: string | null;
  /** When true, overlay the shortcut badge on the icon. */
  isShortcut?: boolean;
  /** Grid row (1-based). */
  row?: number;
  /** Grid column (1-based). */
  col?: number;
}

const { label, icon, path = null, appId = null, isShortcut = false, row, col } = Astro.props;
---

<button
  class:list={['desktop-icon', { 'is-shortcut': isShortcut }]}
  data-launch-app={appId ?? ''}
  data-launch-path={path ?? ''}
  aria-label={`Open ${label}`}
  style={row || col ? `grid-row: ${row ?? 'auto'}; grid-column: ${col ?? 'auto'};` : undefined}
>
  <span class="desktop-icon__img-wrap">
    <img src={icon} alt="" class="desktop-icon__img" aria-hidden="true" />
    <span class="desktop-icon__img-overlay" aria-hidden="true"></span>
  </span>
  <span class="desktop-icon__label">{label}</span>
</button>

<script>
  // Double-click → dispatch xp:launch. Single-click → select.
  const icons = document.querySelectorAll<HTMLElement>('.desktop-icon');

  icons.forEach((icon) => {
    let clickTimer: ReturnType<typeof setTimeout> | null = null;

    icon.addEventListener('click', () => {
      icons.forEach((i) => i.classList.remove('is-selected'));
      icon.classList.add('is-selected');

      if (clickTimer) {
        clearTimeout(clickTimer);
        clickTimer = null;
        const appId = icon.dataset.launchApp || undefined;
        const path = icon.dataset.launchPath || undefined;
        document.dispatchEvent(
          new CustomEvent('xp:launch', { detail: { appId, path } }),
        );
      } else {
        clickTimer = setTimeout(() => {
          clickTimer = null;
        }, 400);
      }
    });
  });

  // Deselect icons when clicking on desktop background
  document.getElementById('desktop')?.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('.desktop-icon')) {
      icons.forEach((i) => i.classList.remove('is-selected'));
    }
  });
</script>
