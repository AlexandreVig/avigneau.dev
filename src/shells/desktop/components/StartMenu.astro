---
import { apps } from "../apps/registry";

const startApps = apps.filter((a) => a.showInStartMenu);

const rightItems = [
  {
    icon: "/icons/folder-32.png",
    label: "My Documents",
    launchAppId: "explorer",
    launchPath: "/My Documents",
  },
  {
    icon: "/icons/my-computer.png",
    label: "My Computer",
    launchAppId: "explorer",
    launchPath: "/",
  },
  { icon: "/icons/control-panel.png", label: "Control Panel" },
  { icon: "/icons/help.png", label: "Help and Support" },
  { icon: "/icons/search.png", label: "Search" },
];
---

<div class="start-menu" id="start-menu">
  <div class="start-menu__header">
    <img src="/icons/user-2.png" alt="" class="start-menu__avatar" />
    <span class="start-menu__username">Alexandre Vigneau</span>
  </div>

  <div class="start-menu__body">
    <div class="start-menu__left">
      {
        startApps.map((app) => (
          <div class="start-menu__item" data-launch-app={app.id}>
            <img src={app.icon} alt="" class="start-menu__item-icon" />
            <span class="start-menu__item-text">{app.title}</span>
          </div>
        ))
      }
      <div style="flex: 1;"></div>
    </div>

    <div class="start-menu__right">
      {
        rightItems.map((item) => (
          <div
            class="start-menu__item"
            data-launch-app={item.launchAppId ?? ""}
            data-launch-path={item.launchPath ?? ""}
          >
            <img src={item.icon} alt="" class="start-menu__item-icon" />
            <span class="start-menu__item-text">{item.label}</span>
          </div>
        ))
      }
      <div class="start-menu__separator"></div>
      <div class="start-menu__item">
        <img src="/icons/connect.png" alt="" class="start-menu__item-icon" />
        <span class="start-menu__item-text">Connect To</span>
      </div>
    </div>
  </div>

  <div class="start-menu__footer">
    <div class="start-menu__footer-btn">
      <img src="/icons/logoff.png" alt="" />
      <span>Log Off</span>
    </div>
    <div class="start-menu__footer-btn">
      <img src="/icons/shutdown.png" alt="" />
      <span>Turn Off</span>
    </div>
  </div>
</div>

<script>
  const startBtn = document.getElementById("taskbar-start")!;
  const startMenu = document.getElementById("start-menu")!;

  startBtn.addEventListener("mousedown", (e) => {
    e.stopPropagation();
    startMenu.classList.toggle("is-open");
  });

  window.addEventListener("mousedown", (e) => {
    if (
      !startMenu.contains(e.target as Node) &&
      !startBtn.contains(e.target as Node)
    ) {
      startMenu.classList.remove("is-open");
    }
  });

  startMenu
    .querySelectorAll<HTMLElement>("[data-launch-app], [data-launch-path]")
    .forEach((item) => {
      item.addEventListener("click", () => {
        const appId = item.dataset.launchApp || undefined;
        const path = item.dataset.launchPath || undefined;
        if (!appId && !path) return;
        document.dispatchEvent(
          new CustomEvent("xp:launch", { detail: { appId, path } }),
        );
        startMenu.classList.remove("is-open");
      });
    });
</script>
