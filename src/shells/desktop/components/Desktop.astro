---
import { desktopNodes, iconForNode } from "../fs/api";
import DesktopIcon from "./DesktopIcon.astro";

const items = desktopNodes();
---

<div id="desktop" role="main" aria-label="Desktop">
  <div id="desktop-icons" aria-label="Desktop icons">
    {
      items.map((node) => {
        const pos = node.desktopPosition;
        if (node.kind === "shortcut") {
          return (
            <DesktopIcon
              label={node.name}
              icon={node.icon ?? iconForNode(node)}
              appId={node.target.appId}
              path={node.target.path}
              isShortcut={node.displayShortcutArrow !== false}
              row={pos?.row}
              col={pos?.col}
            />
          );
        }
        if (node.kind === "file") {
          return (
            <DesktopIcon
              label={node.name}
              icon={iconForNode(node)}
              path={`/Desktop/${node.name}`}
              row={pos?.row}
              col={pos?.col}
            />
          );
        }
        // folders on the desktop → launch explorer at that path
        return (
          <DesktopIcon
            label={node.name}
            icon={iconForNode(node)}
            appId="explorer"
            path={`/Desktop/${node.name}`}
            row={pos?.row}
            col={pos?.col}
          />
        );
      })
    }
  </div>
</div>
