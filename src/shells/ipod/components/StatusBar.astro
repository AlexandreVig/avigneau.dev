---
/**
 * iOS 1 status bar.
 *
 * Left: language button (opens locale dropdown). Center: clock. Right:
 * battery placeholder. The clock is hardcoded to 9:41 AM for now; Step 9
 * wires it to the real system time with a 1-minute tick.
 */
---

<div class="ipod-lang-wrap">
  <div class="ipod-statusbar">
    <span class="left">
      <button
        class="ipod-lang-btn"
        id="ipod-lang-btn"
        type="button"
        aria-haspopup="listbox"
        aria-expanded="false"
      >EN</button>
      <img src="/ipod/wifi.png" alt="wifi" />
    </span>
    <span class="center" id="ipod-clock">9:41 AM</span>
    <span class="right">
      <img src="/ipod/battery.png" alt="battery" />
    </span>
  </div>
  <div
    class="ipod-lang-dropdown"
    id="ipod-lang-dropdown"
    role="listbox"
    hidden
  >
    <button class="ipod-lang-option" data-locale="en" type="button" role="option">
      <span class="check"></span><span class="name">English</span>
    </button>
    <button class="ipod-lang-option" data-locale="fr" type="button" role="option">
      <span class="check"></span><span class="name">Français</span>
    </button>
  </div>
</div>

<script>
  import { getLocale, setLocale, type Locale } from "../../../i18n";

  const btn = document.getElementById("ipod-lang-btn") as HTMLButtonElement;
  const dropdown = document.getElementById("ipod-lang-dropdown") as HTMLElement;
  const options = dropdown.querySelectorAll<HTMLButtonElement>(".ipod-lang-option");

  const locale = getLocale();
  btn.textContent = locale.toUpperCase();

  options.forEach((opt) => {
    if (opt.dataset.locale === locale) {
      opt.querySelector(".check")!.textContent = "\u2713";
      opt.classList.add("is-selected");
    }
    opt.addEventListener("click", () => {
      const target = opt.dataset.locale as Locale | undefined;
      if (target === "en" || target === "fr") setLocale(target);
    });
  });

  function closeDropdown() {
    dropdown.hidden = true;
    btn.setAttribute("aria-expanded", "false");
  }
  function openDropdown() {
    dropdown.hidden = false;
    btn.setAttribute("aria-expanded", "true");
  }

  btn.addEventListener("click", (e) => {
    e.stopPropagation();
    if (dropdown.hidden) openDropdown();
    else closeDropdown();
  });

  window.addEventListener("pointerdown", (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest("#ipod-lang-dropdown, #ipod-lang-btn")) {
      closeDropdown();
    }
  });

  window.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeDropdown();
  });
</script>

<style>
  .ipod-lang-wrap {
    flex-shrink: 0;
    position: relative;
  }

  .ipod-lang-btn {
    appearance: none;
    background: transparent;
    border: none;
    padding: 0 4px;
    margin: 0;
    color: inherit;
    font: inherit;
    font-size: 12px;
    font-weight: 600;
    text-shadow: inherit;
    cursor: pointer;
    border-radius: 3px;
    letter-spacing: 0.3px;
  }
  .ipod-lang-btn:active,
  .ipod-lang-btn[aria-expanded="true"] {
    background: rgba(255, 255, 255, 0.18);
  }

  .ipod-lang-dropdown {
    position: absolute;
    top: 22px;
    left: 4px;
    min-width: 160px;
    padding: 4px 0;
    background: rgba(245, 245, 247, 0.96);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid rgba(0, 0, 0, 0.35);
    border-radius: 8px;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.5);
    z-index: 100;
    color: #000;
    text-shadow: none;
    font-size: 14px;
  }
  .ipod-lang-dropdown[hidden] {
    display: none;
  }

  .ipod-lang-option {
    display: flex;
    align-items: center;
    width: 100%;
    padding: 8px 12px;
    background: transparent;
    border: none;
    color: #000;
    font: inherit;
    text-align: left;
    cursor: pointer;
  }
  .ipod-lang-option:active {
    background: #cfe3ff;
  }
  .ipod-lang-option .check {
    display: inline-block;
    width: 16px;
    margin-right: 6px;
    font-weight: 700;
    color: #2a6df4;
    text-align: center;
  }
  .ipod-lang-option .name {
    flex: 1;
  }

  .ipod-statusbar {
    flex-shrink: 0;
    height: 20px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 6px;
    font-size: 12px;
    font-weight: 600;
    color: #fff;
    background: linear-gradient(
      to bottom,
      #3a3a3a 0%,
      #1a1a1a 50%,
      #0a0a0a 100%
    );
    border-bottom: 1px solid #000;
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.6);
  }

  .left {
    justify-self: start;
    padding-left: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
  }
  .center {
    justify-self: center;
    font-variant-numeric: tabular-nums;
  }
  .right {
    justify-self: end;
    padding-right: 4px;
    display: flex;
    align-items: center;
  }

  .battery {
    display: inline-block;
    position: relative;
    width: 18px;
    height: 9px;
    border: 1px solid #fff;
    border-radius: 1px;
  }
  .battery::after {
    content: "";
    position: absolute;
    right: -3px;
    top: 2px;
    width: 2px;
    height: 3px;
    background: #fff;
  }
  .battery-fill {
    display: block;
    width: 100%;
    height: 100%;
    background: #fff;
  }
</style>
