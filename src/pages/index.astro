---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import DesktopShell from "../shells/desktop/DesktopShell.astro";
import IpodShell from "../shells/ipod/IpodShell.astro";
---

<BaseLayout>
  <DesktopShell />
  <IpodShell />
</BaseLayout>

<script>
  /*
   * Shell chooser — reads the `data-shell` value set by the synchronous
   * detection script in BaseLayout head, removes the losing shell's DOM,
   * and dynamically imports only the winning shell's bootstrap.
   *
   * The inline <style> in BaseLayout already hides the losing shell
   * visually, so this block is purely about (a) not leaving dead DOM
   * and (b) not downloading the unused shell's JS.
   */
  const shell = document.documentElement.dataset.shell;

  if (shell === "ipod") {
    document.getElementById("desktop-shell")?.remove();
    const { mount } = await import("../shells/ipod/bootstrap");
    mount();
  } else {
    document.getElementById("ipod-shell")?.remove();
    const { mount } = await import("../shells/desktop/bootstrap");
    mount();
  }
</script>
