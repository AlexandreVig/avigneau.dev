---
/**
 * Shell-agnostic page scaffolding: <html>, <head>, <body>, locale bootstrap,
 * and the synchronous shell-detection script.
 *
 * Contains no shell-specific markup or CSS. Both the desktop shell
 * (src/shells/desktop/DesktopShell.astro) and the iPod shell
 * (src/shells/ipod/IpodShell.astro) are rendered into the <slot/> here.
 *
 * Shell selection is a two-stage handshake:
 *   1. The inline <script> below runs synchronously in <head> and sets
 *      `html[data-shell="desktop"|"ipod"]` before any paint. The inline
 *      <style> below hides the losing shell via CSS so there is no FOUC.
 *   2. A module <script> in `src/pages/index.astro` reads the same
 *      dataset value, removes the losing shell's DOM, and dynamically
 *      imports only the winning shell's bootstrap.
 */
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = "Alexandre's Computer — Alexandre Vigneau",
  description = "Alexandre Vigneau's portfolio. A Windows XP desktop on the web (and an iPod on mobile) showcasing projects, experience, and contact.",
  ogImage = '/og-image.png',
  noindex = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      name: 'Alexandre Vigneau',
      url: Astro.site?.toString(),
      jobTitle: 'Full-stack developer',
      email: 'mailto:alexandre.vigneau@gmail.com',
      sameAs: [
        'https://github.com/AlexandreVig',
        'https://www.linkedin.com/in/alexandre-vigneau-228812253/',
      ],
      knowsAbout: [
        'Full-stack web development',
        'TypeScript',
        'Astro',
        'Vue',
        'Python',
        'Networking',
        'Network security',
        'AI',
        'GenAI',
      ],
    },
    {
      '@type': 'WebSite',
      name: "Alexandre's Computer",
      url: Astro.site?.toString(),
      inLanguage: ['en', 'fr'],
    },
  ],
};
---

<!doctype html>
<html lang="en" data-default-lang>
  <head>
    <script is:inline>
      // Locale bootstrap — must run before body paints so we don't flash EN.
      (function () {
        var l = localStorage.getItem('xp-locale');
        if (l === 'fr') {
          document.documentElement.lang = 'fr';
        } else if (l === 'en') {
          document.documentElement.lang = 'en';
        } else if (navigator.language && navigator.language.slice(0, 2).toLowerCase() === 'fr') {
          document.documentElement.lang = 'fr';
        }
        document.documentElement.removeAttribute('data-default-lang');
      })();
    </script>
    <script is:inline>
      // Shell selection — must run before body paints so we don't flash the
      // wrong shell. Matches the mobile breakpoint in the module chooser
      // (src/pages/index.astro). Keep them in sync if either is changed.
      (function () {
        var isMobile =
          window.matchMedia('(max-width: 768px)').matches ||
          (window.matchMedia('(pointer: coarse)').matches && window.innerWidth < 1024);
        document.documentElement.dataset.shell = isMobile ? 'ipod' : 'desktop';
      })();
    </script>
    <style is:global>
      /*
       * Hide the losing shell via CSS the instant <html>'s `data-shell`
       * attribute is set. Prevents any frame where both shells are visible.
       * The module chooser later removes the losing shell's DOM entirely.
       */
      html[data-shell='desktop'] #ipod-shell {
        display: none !important;
      }
      html[data-shell='ipod'] #desktop-shell {
        display: none !important;
      }

      /*
       * Both shells are full-viewport UIs; prevent the document itself
       * from scrolling/bouncing behind them.
       */
      html,
      body {
        width: 100%;
        height: 100%;
        margin: 0;
        padding: 0;
        overflow: hidden;
      }

      /*
       * Screen-reader-only block: keeps the SEO content layer in the
       * accessibility tree and indexable by crawlers, but visually hidden
       * so the XP/iPod shells stay pristine. Do not use display:none.
       */
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }
    </style>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow'} />
    <meta name="theme-color" content="#0058e6" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link
      rel="preload"
      as="image"
      href="/wallpaper.webp"
      fetchpriority="high"
      media="(min-width: 769px)"
    />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Alexandre's Computer" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="fr_FR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
  </body>
</html>
