---
import '../styles/global.css';
import Taskbar from '../components/Taskbar.astro';
import StartMenu from '../components/StartMenu.astro';

interface Props {
  title?: string;
}

const { title = 'Alexandre — Portfolio' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Alexandre's portfolio — Windows XP edition" />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body>
    <div id="desktop-shell">
      <div id="desktop-area">
        <slot />
      </div>
      <div id="taskbar-wrapper">
        <StartMenu />
        <Taskbar />
      </div>
    </div>
  </body>
</html>
